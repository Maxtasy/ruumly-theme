{% doc %}
  Renders a Video Component.

  @param {object} video - The shopify media object of type 'video'.
  @param {string} [variant] - Video variant (portrait, landscape, square).
  @param {boolean} [autoplay] - Whether the video should autoplay. Default: false
  @param {boolean} [loop] - Whether the video should loop continuously. Default false
  @param {boolean} [controls] - Whether the video controls should be displayed. Default: true
  @param {boolean} [muted] - Whether the video should be muted. Default: true
{% enddoc %}

{% assign autoplay = autoplay | default: false %}
{% assign loop = loop | default: false %}
{% assign controls = controls | default: true, allow_false: true %}
{% assign muted = muted | default: true, allow_false: true %}

<div
  class="
    Video
    {% if variant %}
      Video--{{ variant | camelcase }}
    {% endif %}
  "
>
  {{ video | video_tag: class: 'Video__Inner', autoplay: autoplay, loop: loop, controls: controls, muted: muted }}
</div>

{% stylesheet %}
  .Video {
    display: block;
    height: 100%;
    width: 100%;
  }

  .Video__Inner {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: var(--aspect-ratio);
  }

  .Video--Portrait {
    --aspect-ratio: 3/4;
  }

  .Video--Landscape {
    --aspect-ratio: 4/3;
  }

  .Video--Square {
    --aspect-ratio: 1;
  }
{% endstylesheet %}
