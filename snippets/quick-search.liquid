{% doc %}
  Renders a Quick Search component.
{% enddoc %}

<quick-search-component class="QuickSearch">
  <form class="Form">
    {% assign search_text_field_placeholder = 'inputs.search.placeholder' | t %}
    {% render 'text-field', placeholder: search_text_field_placeholder, type: 'search' %}
  </form>

  <div class="QuickSearch__Content">
    {% if search.performed %}
      {% if search.results_count > 0 %}
        <div class="QuickSearch__Results">
          {% render 'text', text: 'Results', as: 'h2', variant: 'heading-small' %}

          {% assign product_results = search.results | where: 'object_type', 'product' %}

          {% if product_results.size > 0 %}
            {% render 'product-list', products: product_results, limit: 4, columns_desktop: 4, columns_mobile: 1 %}
            {% if product_results.size > 4 %}
              {% render 'button', text: 'See all results' %}
            {% endif %}
          {% endif %}
        </div>
      {% else %}
        {% render 'text', text: 'No Products found.' %}
      {% endif %}
    {% endif %}
  </div>
</quick-search-component>

{% stylesheet %}
  .QuickSearch {
    display: flex;
    flex-direction: column;
    gap: var(--size-s);
  }

  .QuickSearch__Content {
    overflow: visible;
  }

  .QuickSearch__Results {
    display: flex;
    flex-direction: column;
    gap: var(--size-xs);
    overflow-x: auto;
  }
{% endstylesheet %}
