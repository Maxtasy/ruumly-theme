{% doc %}
  Renders a Range Slider component.

  @param {number} min - The minimum value for the range.
  @param {number} max - The maximum value for the range.
{% enddoc %}

<range-slider-component class="RangeSlider">
  <div class="RangeSlider__NumberInputs">
    <div class="RangeSlider__NumberInput" data-min-input>
      {% render 'number-field', label: 'Min', min: min, max: max, value: 100 %}
    </div>

    <div class="RangeSlider__Separator">-</div>

    <div class="RangeSlider__NumberInput" data-max-input>
      {% render 'number-field', label: 'Max', min: min, max: max, value: 1000 %}
    </div>
  </div>

  <div class="RangeSlider__Track">
    <div class="RangeSlider__Range"></div>

    <input
      type="range"
      min="{{ min }}"
      max="{{ max }}"
      value="{{ min }}"
      step="5"
      data-min-range
    >

    <input
      type="range"
      min="{{ min }}"
      max="{{ max }}"
      value="{{ max }}"
      step="5"
      data-max-range
    >
  </div>
</range-slider-component>

{% stylesheet %}
  .RangeSlider {
    display: flex;
    flex-direction: column;
    gap: var(--size-s);
  }

  .RangeSlider__NumberInputs {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--size-s);
  }

  .RangeSlider__Separator {
    font-size: var(--text-size-body-large);
  }

  .RangeSlider__Track {
    position: relative;
    height: var(--size-xxs);
    background: var(--t-border-muted);
    border-radius: var(--t-border-radius-max);
  }

  .RangeSlider__Range {
    position: absolute;
    top: 0;
    right: calc(var(--RightPercentage, 0) * 1%);
    bottom: 0;
    left: calc(var(--LeftPercentage, 0) * 1%);
    background-color: var(--t-text);
  }

  input[type='number']::-webkit-outer-spin-button,
  input[type='number']::-webkit-inner-spin-button {
    -webkit-appearance: none;
  }

  input[type='range']::-webkit-slider-thumb {
    height: var(--size-m);
    width: var(--size-m);
    border-radius: var(--t-border-radius-circle);
    background-color: var(--t-text);
    pointer-events: auto;
    cursor: grab;
    -webkit-appearance: none;
  }

  input[type='range']::-moz-range-thumb {
    height: var(--size-m);
    width: var(--size-m);
    border-radius: var(--t-border-radius-circle);
    background-color: var(--t-text);
    pointer-events: auto;
    cursor: grab;
  }

  input[type='range'] {
    position: absolute;
    width: 100%;
    height: 100%;
    background: none;
    pointer-events: none;
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    margin: 0;
  }
{% endstylesheet %}
