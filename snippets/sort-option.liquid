{% doc %}
  Renders a Sort Option component.

  @param {object} sort_option - The liquid sort option object.
  @param {boolean} [active] - Whether the sort option is active.
{% enddoc %}

<sort-option-component
  class="SortOption"
  data-sort-option-value="{{ sort_option.value }}"
>
  {% if active %}
    {% render 'button', text: sort_option.name, variant: 'plain', size: 'small', icon: 'check', icon_size: 'small' %}
  {% else %}
    {% render 'button', text: sort_option.name, variant: 'plain', size: 'small' %}
  {% endif %}
</sort-option-component>
