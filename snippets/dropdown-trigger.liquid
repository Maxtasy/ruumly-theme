{% doc %}
  Renders a Dropdown Trigger component.

  @param {string} content - The content for the dropdown trigger.
  @param {string} handle - Connects the dropdown trigger with a dropdown content.
{% enddoc %}

<button is="dropdown-trigger-component" class="DropdownTrigger" data-handle="{{ handle }}">
  <div class="DropdownTrigger__Content">
    {{ content }}
  </div>

  <div class="DropdownTrigger__Icon">
    {% render 'icon', icon: 'chevron-down' %}
  </div>
</button>

{% stylesheet %}
  .DropdownTrigger {
    display: flex;
    align-items: center;
    gap: var(--size-xs);
  }

  .DropdownTrigger__Content {
    display: flex;
    gap: var(--size-xs);
  }

  .DropdownTrigger__Icon {
    transition: rotate var(--transition-duration-medium) var(--transition-timing);
  }

  .DropdownTrigger__Icon--Active {
    rotate: 180deg;
  }

  .DropdownTrigger__Indicator {
    display: none;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    background-color: var(--t-primary);
    border-radius: 50%;
    color: var(--t-background-dark);
    pointer-events: none;
  }

  .DropdownTrigger__Indicator--Active {
    display: flex;
  }
{% endstylesheet %}
