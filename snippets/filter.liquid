{% doc %}
  Renders a Filter Component.

  @param {object} filter - The liquid filter object.
{% enddoc %}

<div class="Filter">
  {% assign handle = filter.label | handleize %}
  {% render 'dropdown-trigger', text: filter.label, handle: handle %}

  <div class="Filter__Content">
    {% capture content %}
      <div class="Filter__DropdownContent">
        <ul
          class="
            Filter__Values
            {% if filter.presentation == 'text' or filter.presentation == nil %}
              Filter__Values--Vertical
            {% endif %}
            u-NoList
          "
        >
          {% for filter_value in filter.values %}
            {% assign is_filter_value_disabled = false %}
            {% if filter_value.count < 1 %}
              {% assign is_filter_value_disabled = true %}
            {% endif %}
            <li>
              {% render 'filter-value', filter_value: filter_value, disabled: is_filter_value_disabled %}
            </li>
          {% endfor %}
        </ul>

        {% assign button_text = 'components.filter.reset_filter' | t %}
        {% render 'button', text: button_text, url: filter.url_to_remove %}
      </div>
    {% endcapture %}

    {% render 'dropdown-content', content: content, handle: handle %}
  </div>
</div>

{% stylesheet %}
  .Filter {
    position: relative;
  }

  .Filter__Content {
    position: absolute;
    top: calc(100% + var(--size-s));
    z-index: 1;
    max-width: 400px;
    white-space: nowrap;
  }

  .Filter__DropdownContent {
    display: flex;
    flex-direction: column;
    gap: var(--size-m);
  }

  .Filter__Values {
    display: flex;
    gap: var(--size-s);
    flex-wrap: wrap;
  }

  .Filter__Values--Vertical {
    flex-direction: column;
  }
{% endstylesheet %}
