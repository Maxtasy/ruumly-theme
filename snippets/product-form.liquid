{% doc %}
  Renders a Product Form component.

  @param {object} product - The product object containing options and values.
  @param {string} [name_prefix] - The prefix for the name attribute of the input elements.
  @param {boolean} [update_variant_url_parameter] - Whether to update the `variant` URL parameter in the URL when the selected variant changes.
  @param {object} [blocks] - The blocks object of a section (for example product configurator).
{% enddoc %}

<product-form-component
  data-update-variant-url-parameter="{{ update_variant_url_parameter | default: false }}"
>
  <form class="ProductForm">
    {% for block in blocks %}
      {% case block.type %}
        {% when 'title' %}
          <div class="ProductForm__Title">
            {% render 'text', text: product.title, variant: 'heading-small', as: 'h1' %}

            {% if block.settings.show_sku and product.selected_or_first_available_variant.sku != blank %}
              <div
                class="ProductForm__Sku"
                {% if block.settings.sku_position == 'above' %}
                  style="--order: -1;"
                {% endif %}
              >
                {% render 'text',
                  text: product.selected_or_first_available_variant.sku,
                  variant: 'body-small',
                  color: 'primary-muted'
                %}
              </div>
            {% endif %}

            {% if block.settings.show_vendor and product.vendor != blank %}
              <div
                class="ProductForm__Vendor"
                {% if block.settings.vendor_position == 'above' %}
                  style="--order: -1;"
                {% endif %}
              >
                {% render 'text', text: product.vendor, variant: 'body-small', color: 'primary' %}
              </div>
            {% endif %}
          </div>

        {% when 'product-variant-selector' %}
          {% render 'product-variant-selector',
            product: product,
            name_prefix: name_prefix,
            visually_hidden: product.has_only_default_variant
          %}

        {% when 'price-list' %}
          {% assign info = 'components.price_list.info_html' | t %}
          {% render 'price-list', price: product.price, compare_at_price: product.compare_at_price, info: info %}

        {% when 'quantity-selector' %}
          {% render 'quantity-selector', quantity: 1 %}

        {% when 'product-rating' %}
          {% if product.metafields.custom.rating.value.rating %}
            {% render 'rating', rating: product.metafields.custom.rating.value.rating, icon_size: 'small' %}
          {% endif %}

        {% when 'buy-buttons' %}
          <div class="ProductForm__BuyButtons">
            <div class="ProductForm__AddToCartButton">
              {% render 'button', text: 'Add to cart', action: 'add-to-cart', full_width: true %}
            </div>

            {% if block.settings.show_wishlist_button %}
              <div class="ProductForm__WishlistButton">
                {% render 'wishlist-buttons', product_id: product.id, full_width: true, handle: product.handle %}
              </div>
            {% endif %}
          </div>

        {% when 'shipping-estimation' %}
          {% liquid
            assign available_text = 'components.shipping_estimation.available' | t
            assign unavailable_text = 'components.shipping_estimation.unavailable' | t
          %}

          {% render 'shipping-estimation',
            available: product.selected_or_first_available_variant.available,
            available_text: available_text,
            unavailable_text: unavailable_text
          %}

        {% when 'selling-points' %}
          {% render 'selling-points',
            selling_points: shop.metaobjects.selling_points['selling-points-1hylegwq'].selling_points.value
          %}
      {% endcase %}
    {% endfor %}
  </form>
</product-form-component>

{% stylesheet %}
  .ProductForm {
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    gap: var(--size-m);
    padding: var(--size-m);
    background-color: var(--t-background);
    background: var(--t-gradient-background);
    border: var(--border-width) solid var(--t-border-card);
    border-top-color: var(--t-highlight);
    border-radius: var(--t-border-radius);
    box-shadow: var(--box-shadow);
  }

  .ProductForm__Title {
    display: flex;
    flex-direction: column;
    gap: var(--size-xxs);
  }

  .ProductForm__Sku {
    order: var(--order, 1);
  }

  .ProductForm__Vendor {
    order: var(--order, 1);
  }

  .ProductForm__BuyButtons {
    display: flex;
    align-items: center;
    gap: var(--size-xxs);
    width: 100%;
  }

  .ProductForm__AddToCartButton {
    flex: 1;
  }

  .ProductForm__WishlistButton .Button {
    /* We set a fixed width to avoid layout shift when the wishlist button appears and disappears. */
    width: 44px;
    height: 44px;
  }

  @media screen and (min-width: 769px) {
    .ProductForm {
      position: sticky;

      /* We add the section padding here since we want to maintain the distance to all the sticky elements in the
      header group. */
      top: calc(var(--total-sticky-height) + var(--section-padding-block-m));

      padding: var(--size-l);
    }
  }
{% endstylesheet %}
