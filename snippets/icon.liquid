{% doc %}
  Renders an Icon component.
  Social icons are from Font Awesome, the rest is from Lucide.

  @param {string} icon - The icon to display.
  @param {string} [size] - The size of the icon.
  @param {string} [defs] - The defs to display.
  @param {string} [fill_gradient] - The fill gradient to display.
  @param {string} [stroke_color] - The color of the stroke.
{% enddoc %}

{% assign size = size | default: 'medium' %}

<div class="Icon Icon--Size{{ size | camelcase }}">
  {% case icon %}
