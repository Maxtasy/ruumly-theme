{% doc %}
  Renders a Quantity Selector component.

  @param {number} quantity - The currently selected quantity.
  @param {number} [max] - The maximum quantity allowed.
{% enddoc %}

<quantity-selector-component
  class="QuantitySelector"
  data-quantity="{{ quantity }}"
  {% if max %}
    data-max="{{ max }}"
  {% endif %}
>
  {% render 'button',
    variant: 'plain',
    icon: 'minus',
    action: 'decrement',
    size: 'small',
    aria_label_key: 'components.minus_button.aria_label',
    type: 'button'
  %}

  <div class="QuantitySelector__Loading">
    {% render 'loading-spinner', size: 'medium' %}
  </div>

  <span class="QuantitySelector__Quantity">
    {{ quantity }}
  </span>

  {% render 'button',
    variant: 'plain',
    icon: 'plus',
    action: 'increment',
    size: 'small',
    aria_label_key: 'components.plus_button.aria_label',
    type: 'button'
  %}

  <div class="QuantitySelector__Error">
    {% assign alert_text = 'components.quantity_selector.max_quantity_reached' | t %}
    {% render 'alert', text: alert_text, variant: 'warning', text_variant: 'body-small', no_icon: true %}
  </div>
</quantity-selector-component>

{% stylesheet %}
  .QuantitySelector {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--size-xs);
    border: var(--border-width) var(--border-style) var(--t-border);
  }

  .QuantitySelector__Quantity {
    display: flex;
    justify-content: center;
    min-width: 2ch;
    font-variant-numeric: tabular-nums;
  }

  .QuantitySelector__Loading {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    color: #fff;
    background-color: var(--t-backdrop-background-color);
  }

  .QuantitySelector__Loading--Active {
    display: flex;
  }

  .QuantitySelector__Error {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    margin-top: var(--size-xxs);
    display: none;
  }

  .QuantitySelector__Error--Active {
    display: block;
  }
{% endstylesheet %}
