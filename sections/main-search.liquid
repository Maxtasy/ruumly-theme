<section
  class="
    Section
    Section--PaddingBlock{{ section.settings.padding_block | camelcase }}
    ColorScheme--{{ section.settings.color_scheme.id | camelcase }}
  "
>
  <div class="Section__Inner">
    {% if section.settings.heading != blank %}
      {% render 'text', text: section.settings.heading, as: 'h1', variant: 'heading-medium' %}
    {% endif %}

    <search-component class="Search">
      <form class="Form">
        {% assign search_text_field_placeholder = 'inputs.search.placeholder' | t %}
        {% render 'text-field', placeholder: search_text_field_placeholder, type: 'search' %}

        {% assign submit_button_text = 'global.submit' | t %}
        {% render 'button', text: submit_button_text %}
      </form>

      <div class="Search__Content">
        {% if search.performed %}
          {% if search.results_count > 0 %}
            <div class="Search__Results">
              {% assign results_heading = section.settings.results_heading
                | append: ' ('
                | append: search.results_count
                | append: ')'
              %}
              {% render 'text', text: results_heading, as: 'h2', variant: 'heading-small' %}

              {% assign product_results = search.results | where: 'object_type', 'product' %}
              {% assign article_results = search.results | where: 'object_type', 'article' %}
              {% assign page_results = search.results | where: 'object_type', 'page' %}

              <div class="Search__ResultCategory">
                {% assign products_heading = 'global.products' | t %}
                {% render 'text', text: products_heading, as: 'b' %}

                {% if product_results.size > 0 %}
                  {% render 'product-grid', products: product_results %}
                {% else %}
                  {% render 'text', text: 'No matching products found.', variant: 'body-small' %}
                {% endif %}
              </div>

              <div class="Search__ResultCategory">
                {% render 'text', text: 'Articles', as: 'b' %}

                {% if article_results.size > 0 %}
                  {% render 'blog-article-list', blog_articles: article_results, enable_pagination: false %}
                {% else %}
                  {% render 'text', text: 'No matching articles found.', variant: 'body-small' %}
                {% endif %}
              </div>

              <div class="Search__ResultCategory">
                {% render 'text', text: 'Pages', as: 'b' %}

                {% if page_results.size > 0 %}
                  {% for page_result in page_results %}
                    {% render 'link', text: page_result.title, url: page_result.url %}
                  {% endfor %}
                {% else %}
                  {% render 'text', text: 'No matching pages found.', variant: 'body-small' %}
                {% endif %}
              </div>
            </div>
          {% else %}
            {% render 'empty-state', heading: 'No results found', text: 'Try again using another search term.' %}
          {% endif %}
        {% endif %}
      </div>
    </search-component>
  </div>
</section>

{% stylesheet %}
  .Search {
    display: flex;
    flex-direction: column;
    gap: var(--size-s);
  }

  .Search__Results {
    display: flex;
    flex-direction: column;
    gap: var(--size-xs);
  }

  .Search__ResultCategory {
    display: flex;
    flex-direction: column;
    gap: var(--size-xxs);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main_search.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.headers.section_appearance.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.settings.color_scheme.label",
      "info": "t:sections.all.settings.color_scheme.info"
    },
    {
      "type": "select",
      "id": "padding_block",
      "label": "t:sections.all.settings.padding_block.label",
      "default": "medium",
      "options": [
        { "value": "none", "label": "t:sections.all.settings.padding_block.options.none.label" },
        { "value": "small", "label": "t:sections.all.settings.padding_block.options.small.label" },
        { "value": "medium", "label": "t:sections.all.settings.padding_block.options.medium.label" },
        { "value": "large", "label": "t:sections.all.settings.padding_block.options.large.label" }
      ]
    },
    {
      "type": "number",
      "id": "columns_mobile",
      "label": "t:sections.all.settings.columns_mobile.label",
      "default": 1
    },
    {
      "type": "number",
      "id": "columns_desktop",
      "label": "t:sections.all.settings.columns_desktop.label",
      "default": 3
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.section_content.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main_search.settings.heading.label",
      "default": "t:sections.main_search.settings.heading.default"
    },
    {
      "type": "text",
      "id": "results_heading",
      "label": "t:sections.main_search.settings.results_heading.label",
      "default": "t:sections.main_search.settings.results_heading.default"
    }
  ]
}
{% endschema %}
