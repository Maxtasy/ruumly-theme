{% assign sub_collections = collection.metafields.custom.sub_collections.value %}
{% assign parent_collection = collection.metafields.custom.parent_collection.value %}

{% if sub_collections != blank %}
  {% assign navigation_collections = sub_collections %}
{% elsif parent_collection != blank %}
  {% assign navigation_collections = parent_collection.metafields.custom.sub_collections.value %}
{% endif %}

{% if navigation_collections != blank %}
  <section
    class="
      Section
      Section--PaddingBlock{{ section.settings.padding_block | camelcase }}
      ColorScheme--{{ section.settings.color_scheme.id | camelcase }}
    "
  >
    <div class="Section__Inner">
      <ul class="CollectionNavigation u-NoList">
        {% for navigation_collection in navigation_collections %}
          {% assign navigation_image = navigation_collection.metafields.custom.collection_navigation_image.value
            | default: navigation_collection.image
          %}

          {% assign is_active = false %}

          {% if navigation_collection.handle == collection.handle %}
            {% assign is_active = true %}
          {% endif %}

          <li class="CollectionNavigation__Item">
            {% render 'collection-navigation-item',
              title: navigation_collection.title,
              url: navigation_collection.url,
              image: navigation_image,
              is_active: is_active
            %}
          </li>
        {% endfor %}
      </ul>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "t:sections.collection_navigation.name",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.headers.section_appearance.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.settings.color_scheme.label",
      "info": "t:sections.all.settings.color_scheme.info"
    },
    {
      "type": "select",
      "id": "padding_block",
      "label": "t:sections.all.settings.padding_block.label",
      "default": "medium",
      "options": [
        { "value": "none", "label": "t:sections.all.settings.padding_block.options.none.label" },
        { "value": "small", "label": "t:sections.all.settings.padding_block.options.small.label" },
        { "value": "medium", "label": "t:sections.all.settings.padding_block.options.medium.label" },
        { "value": "large", "label": "t:sections.all.settings.padding_block.options.large.label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection_navigation.presets.collection_navigation.name"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  .CollectionNavigation {
    display: flex;
    justify-content: center;
    gap: var(--size-s);
  }
{% endstylesheet %}
