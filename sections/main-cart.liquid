<section
  class="
    Section
    Section--PaddingBlock{{ section.settings.padding_block | camelcase }}
    ColorScheme--{{ section.settings.color_scheme.id | camelcase }}
  "
>
  <div class="Section__Inner">
    <div class="Cart">
      <div class="Cart__LineItems">
        {% for item in cart.items %}
          {% render 'line-item',
            product_title: item.title,
            variant_title: item.variant.title,
            image: item.image,
            price: item.variant.price,
            compare_at_price: item.variant.compare_at_price,
            quantity: item.quantity,
            url: item.url,
            key: item.key,
            variant_id: item.variant.id,
            inventory_quantity: item.variant.inventory_quantity
          %}
        {% endfor %}
      </div>

      <div class="Cart__GiftCode">
        {% render 'text-field', label: 'Gift Code' %}

        {% assign submit_button_text = 'global.submit' | t %}
        {% render 'button', text: submit_button_text %}
      </div>

      <div class="Cart__Subtotal">
        {% render 'text', text: 'Subtotal:', as: 'b' %}

        {% render 'price-list', price: cart.original_total_price %}
      </div>

      <div class="Cart__Shipping"></div>

      <div class="Cart__Total">
        {% render 'text', text: 'Total:', as: 'b' %}

        {% render 'price-list', price: cart.total_price %}
      </div>

      <div class="Cart__Checkout">
        {% assign checkout_button_text = 'global.checkout' | t %}
        {% render 'button', text: checkout_button_text %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .Cart {
    display: flex;
    flex-direction: column;
    gap: var(--size-m);
  }

  .Cart__LineItems {
    display: flex;
    flex-direction: column;
    gap: var(--size-xxs);
  }

  .Cart__GiftCode {
    display: flex;
    flex-direction: column;
    gap: var(--size-xs);
  }

  .Cart__Subtotal {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--size-xs);
  }

  .Cart__Total {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--size-xs);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main_cart.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.headers.section_appearance.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.settings.color_scheme.label",
      "info": "t:sections.all.settings.color_scheme.info"
    },
    {
      "type": "select",
      "id": "padding_block",
      "label": "t:sections.all.settings.padding_block.label",
      "default": "medium",
      "options": [
        { "value": "none", "label": "t:sections.all.settings.padding_block.options.none.label" },
        { "value": "small", "label": "t:sections.all.settings.padding_block.options.small.label" },
        { "value": "medium", "label": "t:sections.all.settings.padding_block.options.medium.label" },
        { "value": "large", "label": "t:sections.all.settings.padding_block.options.large.label" }
      ]
    }
  ]
}
{% endschema %}
