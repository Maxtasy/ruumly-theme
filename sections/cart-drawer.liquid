{% capture cart_drawer_content %}
  {% render 'cart-drawer',
    enable_free_shipping_alert: section.settings.enable_free_shipping_alert,
    enable_free_shipping_progress: section.settings.enable_free_shipping_progress,
    free_shipping_remaining_text: section.settings.free_shipping_remaining_text,
    free_shipping_reached_text: section.settings.free_shipping_reached_text,
    empty_state_heading: section.settings.cart_empty_state_heading,
    empty_state_text: section.settings.cart_empty_state_text,
    empty_state_link: section.settings.cart_empty_state_link,
    empty_state_link_text: section.settings.cart_empty_state_link_text,
  %}
{% endcapture %}

{% render 'drawer',
  name: 'cart',
  heading: 'Cart',
  content: cart_drawer_content,
  from: section.settings.from,
  color_scheme: section.settings.color_scheme
%}

{% schema %}
{
  "name": "t:sections.cart_drawer.name",
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["index", "product", "collection", "page", "blog", "article"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.headers.section_appearance.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.settings.color_scheme.label",
      "default": "default",
      "info": "t:sections.all.settings.color_scheme.info"
    },
    {
      "type": "select",
      "id": "from",
      "label": "t:sections.cart_drawer.settings.from.label",
      "default": "right",
      "options": [
        {
          "value": "left",
          "label": "t:sections.cart_drawer.settings.from.options.left.label"
        },
        {
          "value": "right",
          "label": "t:sections.cart_drawer.settings.from.options.right.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.section_content.content"
    },
    {
      "type": "checkbox",
      "id": "enable_free_shipping_alert",
      "label": "t:sections.all.settings.enable_free_shipping_alert.label",
      "default": true,
      "info": "t:sections.all.settings.enable_free_shipping_alert.info"
    },
    {
      "type": "checkbox",
      "id": "enable_free_shipping_progress",
      "label": "t:sections.all.settings.enable_free_shipping_progress.label",
      "default": true,
      "info": "t:sections.all.settings.enable_free_shipping_progress.info",
      "visible_if": "{{ section.settings.enable_free_shipping_alert }}"
    },
    {
      "type": "text",
      "id": "free_shipping_remaining_text",
      "label": "t:sections.all.settings.free_shipping_remaining_text.label",
      "default": "t:sections.all.settings.free_shipping_remaining_text.default",
      "info": "t:sections.all.settings.free_shipping_remaining_text.info",
      "visible_if": "{{ section.settings.enable_free_shipping_alert }}"
    },
    {
      "type": "text",
      "id": "free_shipping_reached_text",
      "label": "t:sections.all.settings.free_shipping_reached_text.label",
      "default": "t:sections.all.settings.free_shipping_reached_text.default",
      "visible_if": "{{ section.settings.enable_free_shipping_alert }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.empty_state.content"
    },
    {
      "type": "text",
      "id": "cart_empty_state_heading",
      "label": "t:sections.all.settings.cart_empty_state_heading.label",
      "default": "t:sections.all.settings.cart_empty_state_heading.default"
    },
    {
      "type": "text",
      "id": "cart_empty_state_text",
      "label": "t:sections.all.settings.cart_empty_state_text.label",
      "default": "t:sections.all.settings.cart_empty_state_text.default"
    },
    {
      "type": "url",
      "id": "cart_empty_state_link",
      "label": "t:sections.all.settings.cart_empty_state_link.label",
      "default": "/collections"
    },
    {
      "type": "text",
      "id": "cart_empty_state_link_text",
      "label": "t:sections.all.settings.cart_empty_state_link_text.label",
      "default": "t:sections.all.settings.cart_empty_state_link_text.default"
    }
  ],
  "presets": [
    {
      "name": "t:sections.cart_drawer.presets.cart_drawer.name",
      "category": "t:sections.cart_drawer.presets.cart_drawer.category"
    }
  ]
}
{% endschema %}
