<section
  class="
    Section
    Section--PaddingBlock{{ section.settings.padding_block | camelcase }}
    ColorScheme--{{ section.settings.color_scheme.id | camelcase }}
  "
>
  <div class="Section__Inner">
    <wishlist-section-component
      class="WishlistSection"
      data-quick-add-button-enabled="{{ section.settings.enable_quick_add_button }}"
      data-wishlist-button-enabled="{{ section.settings.enable_wishlist_button }}"
    >
      {% render 'text', text: section.settings.heading, as: 'h2', variant: 'heading-medium' %}

      <div class="WishlistSection__EmptyState">
        {% render 'empty-state',
          heading: section.settings.empty_state_heading,
          text: section.settings.empty_state_text,
          link: section.settings.empty_state_button_link,
          link_text: section.settings.empty_state_button_text
        %}
      </div>

      {% render 'product-list',
        columns_mobile: section.settings.columns_mobile,
        columns_desktop: section.settings.columns_desktop
      %}

      <template id="product-card-skeleton">
        <li>
          {% render 'product-card-skeleton' %}
        </li>
      </template>
    </wishlist-section-component>
  </div>
</section>

{% stylesheet %}
  .WishlistSection__EmptyState {
    display: none;
    padding-block: var(--size-m);
  }

  .WishlistSection__EmptyState--Active {
    display: block;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.wishlist.name",
  "disabled_on": {
    "templates": [
      "index",
      "404",
      "article",
      "blog",
      "cart",
      "collection",
      "customers/account",
      "customers/activate_account",
      "customers/addresses",
      "customers/login",
      "customers/order",
      "customers/register",
      "customers/reset_password",
      "gift_card",
      "list-collections",
      "product",
      "search"
    ],
    "groups": ["header", "footer", "aside"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.headers.section_appearance.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.settings.color_scheme.label",
      "info": "t:sections.all.settings.color_scheme.info"
    },
    {
      "type": "select",
      "id": "padding_block",
      "label": "t:sections.all.settings.padding_block.label",
      "default": "medium",
      "options": [
        { "value": "none", "label": "t:sections.all.settings.padding_block.options.none.label" },
        { "value": "small", "label": "t:sections.all.settings.padding_block.options.small.label" },
        { "value": "medium", "label": "t:sections.all.settings.padding_block.options.medium.label" },
        { "value": "large", "label": "t:sections.all.settings.padding_block.options.large.label" }
      ]
    },
    {
      "type": "number",
      "id": "columns_mobile",
      "label": "t:sections.all.settings.columns_mobile.label",
      "default": 2
    },
    {
      "type": "number",
      "id": "columns_desktop",
      "label": "t:sections.all.settings.columns_desktop.label",
      "default": 4
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.section_content.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.all.settings.heading.label",
      "default": "t:sections.all.settings.heading.default"
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add_button",
      "label": "t:sections.all.settings.enable_quick_add_button.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_wishlist_button",
      "label": "t:sections.all.settings.enable_wishlist_button.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.empty_state.content"
    },
    {
      "type": "text",
      "id": "empty_state_heading",
      "label": "t:sections.wishlist.settings.empty_state_heading.label",
      "default": "t:sections.wishlist.settings.empty_state_heading.default"
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "t:sections.wishlist.settings.empty_state_text.label",
      "default": "t:sections.wishlist.settings.empty_state_text.default"
    },
    {
      "type": "text",
      "id": "empty_state_button_text",
      "label": "t:sections.wishlist.settings.empty_state_button_text.label",
      "default": "t:sections.wishlist.settings.empty_state_button_text.default"
    },
    {
      "type": "url",
      "id": "empty_state_button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "t:sections.wishlist.presets.wishlist.name"
    }
  ]
}
{% endschema %}
